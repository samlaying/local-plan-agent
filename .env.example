# App
APP_ENV=development
APP_NAME=local-plan-agent
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_MAP_PROVIDER=mock

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=local_plan_agent
POSTGRES_USER=local_plan
POSTGRES_PASSWORD=local_plan_password
DATABASE_URL=postgresql+psycopg://local_plan:local_plan_password@postgres:5432/local_plan_agent

# Agent
AGENT_BACKEND=custom_workflow
AGENT_MAX_STEPS=12
AGENT_ENABLE_VALIDATOR=true

# Mock data
MOCK_DATA_DIR=/app/data/mock
USE_MOCK_POI=true
USE_MOCK_RESTAURANT=true
USE_MOCK_EXECUTION=true

# Real API placeholders
AMAP_API_KEY=
AMAP_API_BASE_URL=https://restapi.amap.com

# Observability
LOG_LEVEL=INFO
ENABLE_TOOL_CALL_LOG=true
